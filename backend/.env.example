SESSION_SECRET=calvoro-super-secret-key-change-in-production
PORT=3000

# Same Google OAuth 2.0 Client ID as frontend (for Google sign-in → server session)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# Set to true to use MySQL; false or unset = JSON files in data/
USE_MYSQL=true

# Database Configuration (when USE_MYSQL=true)
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=calvoro_db

# PayHere Configuration (Sandbox)
PAYHERE_MERCHANT_ID=1223807
PAYHERE_MERCHANT_SECRET=YOUR_MERCHANT_SECRET_HERE
PAYHERE_MODE=sandbox

# Stripe Donations (Test mode)
# Get these from Stripe Dashboard → Developers → API keys
STRIPE_SECRET_KEY=sk_test_your_key_here
# Stripe Webhook signing secret (CLI or Dashboard endpoint)
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Public site base URL (used for Stripe success/cancel redirect)
BASE_URL=http://localhost:3000
