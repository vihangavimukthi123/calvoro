<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= subject %></title>
    <style>
        body { font-family: 'Inter', Arial, sans-serif; line-height: 1.6; color: #333; margin: 0; padding: 0; background: #f4f4f4; }
        .container { max-width: 600px; margin: 20px auto; padding: 0; border: none; background: #fff; border-radius: 8px; overflow: hidden; }
        .hero { position: relative; width: 100%; height: auto; }
        .hero img { width: 100%; display: block; }
        .content { padding: 40px; text-align: center; }
        .content h1 { font-size: 28px; line-height: 1.2; margin-bottom: 20px; color: #000; }
        .content p { font-size: 16px; color: #555; margin-bottom: 30px; }
        .btn { display: inline-block; padding: 16px 32px; color: #fff; background: #000; text-decoration: none; border-radius: 4px; font-weight: bold; font-size: 18px; }
        .footer { text-align: center; font-size: 14px; color: #888; padding: 40px 20px; background: #fafafa; border-top: 1px solid #eee; }
        .footer a { color: #000; font-weight: bold; margin: 0 10px; text-decoration: none; }
    </style>
</head>
<body>
    <div class="container">
        <% if (heroImage) { %>
        <div class="hero">
            <img src="<%= heroImage %>" alt="Seasonal Offer">
        </div>
        <% } %>
        <div class="content">
            <h1><%= title %></h1>
            <p><%= body %></p>
            <% if (ctaText && ctaUrl) { %>
            <a href="<%= ctaUrl %>" class="btn"><%= ctaText %></a>
            <% } %>
        </div>
        <div class="footer">
            <p>&copy; 2026 Calvoro. All rights reserved.</p>
            <p>
                <a href="https://calvoro.com/men.html">Men</a>
                <a href="https://calvoro.com/women.html">Women</a>
                <a href="https://calvoro.com/account.html">Account</a>
            </p>
            <p style="margin-top:20px; font-size:12px; color:#aaa;">You're receiving this because you subscribed to Calvoro updates. <br>To unsubscribe, <a href="#" style="color:#aaa; text-decoration:underline;">click here</a>.</p>
        </div>
    </div>
</body>
</html>
